{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item in the inventory catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "category": { "type": "string" },
        "currentStock": { "type": "number" },
        "minStock": { "type": "number" },
        "unit": { "type": "string" },
        "price": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "currentStock", "unit"]
    },
    "StockLog": {
      "title": "StockLog",
      "description": "A record of an inventory count, adjustment, or sale transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["count", "in", "out", "adjustment"] },
        "quantity": { "type": "number" },
        "previousStock": { "type": "number" },
        "newStock": { "type": "number" },
        "difference": { "type": "number" },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "operator": { "type": "string" }
      },
      "required": ["id", "productId", "productName", "type", "quantity", "previousStock", "newStock", "timestamp"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of physical products in stock."
    },
    "stockLogs/{logId}": {
      "schema": "StockLog",
      "description": "Activity logs tracking every count or stock level adjustment."
    }
  }
}
